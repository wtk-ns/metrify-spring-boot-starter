  "panels": [
    {
      "title": "Order Checkout - Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(demo_order_checkout_timer_seconds_bucket[1m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(demo_order_checkout_timer_seconds_bucket[1m]))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, rate(demo_order_checkout_timer_seconds_bucket[1m]))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Order Checkout - Throughput",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "rate(demo_order_checkout_count_total[1m])", "legendFormat": "orders/sec" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Payment Processed (rate)",
